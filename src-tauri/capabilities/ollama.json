{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "ollama-network",
    "description": "Разрешение на исходящие HTTP-запросы к локальному ядру Ollama (SSRF Guard activated)",
    "windows": [
        "main"
    ],
    "permissions": [
        "http:default",
        {
            "identifier": "http:default",
            "allow": [
                {
                    "url": "http://127.0.0.1:11434"
                },
                {
                    "url": "http://127.0.0.1:11434/*"
                },
                {
                    "url": "http://localhost:11434"
                },
                {
                    "url": "http://localhost:11434/*"
                }
            ]
        }
    ]
}