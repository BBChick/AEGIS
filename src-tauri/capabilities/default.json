{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "store:default",
    "opener:default",
    "notification:default",
    "http:default",
    {
      "identifier":"http:default",
      "allow": [
        { "url": "http://127.0.0.1:11434/*" },
        { "url": "http://localhost:11434/*" }
      ]
    }
  ]
}